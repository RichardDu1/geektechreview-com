---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews');
// Sort by date descending
const sortedReviews = allReviews.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featuredReview = sortedReviews[0];
const sidebarReviews = sortedReviews.slice(1, 4);

const pageTitle = 'Deep Dive Tech Reviews | Geek Tech Review';
const pageDescription = 'In-depth, brutally honest reviews of developer laptops, noise-canceling audio, and tech hardware.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://geektechreview.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <!-- Magazine Header -->
  <header class="border-b-[4px] border-black pb-8 pt-12 px-6 max-w-[1400px] mx-auto">
    <div class="flex flex-col items-center">
      <div class="font-bold tracking-widest uppercase text-xs text-muted mb-4 border-b border-black pb-1">Issue #042 • Late 2026</div>
      <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-center mb-6">
        GEEK TECH.
      </h1>
      <nav class="flex gap-8 font-sans font-bold uppercase text-sm border-y border-border py-4 w-full justify-center">
        <a href="/en/reviews/" class="hover:text-primary transition-colors">All Reviews</a>
        <a href="/en/reviews/" class="hover:text-primary transition-colors">Laptops</a>
        <a href="/en/reviews/" class="hover:text-primary transition-colors">Audio</a>
        <a href="/en/reviews/" class="hover:text-primary transition-colors">Keyboards</a>
      </nav>
    </div>
  </header>

  <!-- Editorial Asymmetrical Layout -->
  <main class="max-w-[1400px] mx-auto px-6 py-12">
    <div class="magazine-grid">
      
      <!-- Featured Story (Spans 8 cols) -->
      <article class="col-span-12 md:col-span-8 group cursor-pointer">
        {featuredReview ? (
          <a href={`/en/reviews/${featuredReview.id.split('/').pop()}`} class="block">
            <div class="relative overflow-hidden mb-6 aspect-[16/9] bg-neutral border border-border">
              <div class="absolute inset-0 bg-gradient-to-tr from-black/20 to-transparent z-10"></div>
              <div class="w-full h-full bg-slate-200 flex items-center justify-center group-hover:scale-105 transition-transform duration-700">
                <span class="font-sans text-muted">Hero Graphic placeholder</span>
              </div>
              <div class="absolute top-4 left-4 z-20 bg-primary text-white font-bold uppercase text-xs px-3 py-1 shadow-[-4px_4px_0_0_#000]">
                {featuredReview.data.category}
              </div>
            </div>
            
            <h2 class="text-4xl md:text-5xl mb-4 leading-tight group-hover:underline decoration-[4px] decoration-primary underline-offset-4">
              {featuredReview.data.title}
            </h2>
            <p class="text-xl text-muted font-sans max-w-2xl leading-relaxed mb-6">
              {featuredReview.data.description}
            </p>
            <div class="flex items-center gap-4 text-sm font-bold uppercase font-sans">
              <span>By {featuredReview.data.author}</span>
              <span class="text-primary">•</span>
              <span class="text-accent text-lg">★ {featuredReview.data.score}</span>
            </div>
          </a>
        ) : (
          <div class="text-center py-20 text-muted border border-dashed border-border">Awaiting Editorial Sync...</div>
        )}
      </article>

      <!-- Sidebar Stories (Spans 4 cols) -->
      <aside class="col-span-12 md:col-span-4 flex flex-col gap-10 border-t md:border-t-0 md:border-l border-border pt-10 md:pt-0 md:pl-10">
        
        <div>
          <h3 class="font-bold text-xs uppercase tracking-widest text-muted border-b border-black pb-2 mb-6">Trending Now</h3>
          
          {sidebarReviews.length > 0 ? sidebarReviews.map(review => (
            <article class="mb-8 group cursor-pointer">
              <a href={`/en/reviews/${review.id.split('/').pop()}`} class="block">
                <h4 class="text-2xl mb-2 leading-snug group-hover:text-primary transition-colors">{review.data.title}</h4>
                <div class="flex items-center gap-2 text-xs font-bold uppercase text-muted font-sans">
                  <span class="text-accent text-lg">★ {review.data.score}</span>
                  <span>{review.data.category}</span>
                </div>
              </a>
            </article>
          )) : (
            <div class="text-sm text-muted">No trending stories yet.</div>
          )}
        </div>
        
        <!-- Newsletter Box -->
        <div class="bg-black text-white p-8 mt-auto shadow-[8px_8px_0_0_var(--color-primary)]">
          <h4 class="text-3xl font-serif mb-4">Tech brutally reviewed. Every Friday.</h4>
          <input type="email" placeholder="Your Email" class="w-full bg-transparent border-b-2 border-white/30 text-white py-2 mb-6 font-sans focus:outline-none focus:border-primary transition-colors" />
          <button class="w-full bg-primary text-black font-bold uppercase tracking-widest py-3 hover:bg-white transition-colors">Subscribe</button>
        </div>

      </aside>
    </div>
  </main>
</BaseLayout>
