---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = 'Geek Tech Review — Hardcore Tech & Hardware Reviews';
const pageDescription = 'Deep dives, benchmarks, and honest reviews of the latest PC hardware, gadgets, and tech gear.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://geektechreview.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="Hardcore Benchmarks & Tech Reviews" subtitle="We push hardware to the limit so you know what to buy." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="PC Builds" description="Custom PC Guides" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="Components" description="GPUs, CPUs, Motherboards" href="/en/categories/c2/" tag="New" />
      <Card title="Peripherals" description="Mice, Keyboards, Monitors" href="/en/categories/c3/" />
      <Card title="Mobile" description="Smartphones & Tablets" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="RTX 5090 Review & Benchmarks" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="Best Gaming Mice 2026" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="AMD Ryzen 9000 Tested" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>
